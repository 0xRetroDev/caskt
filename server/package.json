{
  "name": "caskt-server",
  "version": "0.1.0",
  "description": "Local, headless CS2 inventory and storage-unit management. Indexes everything you own including casket contents, values it, and runs paced lock-aware bulk moves. Runs on your own machine against your own account.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "login": "tsx bin/login.ts",
    "build-schema": "tsx bin/build-schema.ts",
    "build-prices": "tsx bin/build-prices.ts",
    "serve": "tsx bin/serve.ts",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "globaloffensive": "^3.1.2",
    "steam-session": "^1.9.4",
    "steam-user": "^5.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
